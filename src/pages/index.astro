---
import BaseLayout from '../layouts/BaseLayout.astro';
import Nav from '../components/Nav.astro';
import Hero from '../components/Hero.astro';
import NotchMockup from '../components/NotchMockup.astro';
import Modes from '../components/Modes.astro';
import AgentSupport from '../components/AgentSupport.astro';
import Features from '../components/Features.astro';
import WhyBuilt from '../components/WhyBuilt.astro';
import BlogPreview from '../components/BlogPreview.astro';
import FAQ from '../components/FAQ.astro';
import Footer from '../components/Footer.astro';

const jsonLd = {
  '@context': 'https://schema.org',
  '@type': 'SoftwareApplication',
  name: 'xisland',
  alternateName: 'The Dynamic Island for AI Coding Agents',
  applicationCategory: 'DeveloperApplication',
  operatingSystem: 'macOS',
  offers: { '@type': 'Offer', price: '0', priceCurrency: 'USD' },
  description: 'The ultimate dynamic island for AI coding agents. Monitor Claude Code, Codex, Gemini CLI, and OpenCode from your macOS notch. Approve, answer, and jump back — without leaving your editor.',
  url: 'https://xisland.app',
  downloadUrl: 'https://github.com/bluedusk/xisland/releases',
  author: { '@type': 'Person', name: 'dan' },
  featureList: [
    'Monitor AI coding agent sessions from the macOS notch',
    'Approve file edits, commands, and deletions before they run',
    'Answer agent questions from a popup without switching windows',
    'Jump to the right terminal session with one click',
    'Vim-style keyboard navigation',
    'Native Swift app — no Electron',
  ],
};
---

<BaseLayout jsonLd={jsonLd}>
  <Nav />
  <Hero />
  <NotchMockup />
  <WhyBuilt />
  <Modes />
  <AgentSupport />
  <Features />
  <BlogPreview />
  <FAQ />
  <Footer />
</BaseLayout>
