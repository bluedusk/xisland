---
import BaseLayout from '../layouts/BaseLayout.astro';
import Nav from '../components/Nav.astro';
import Footer from '../components/Footer.astro';
---

<BaseLayout
  title="Docs — xisland"
  description="How to install xisland, connect your AI agents, reinstall hooks, and label sessions."
>
  <Nav />
  <div class="docs-root">

    <aside class="sidenav">
      <nav>
        <p class="nav-group-label">Getting started</p>
        <a href="#installation" class="nav-link">Installation</a>
        <a href="#reinstall-hooks" class="nav-link">Reinstall hooks</a>
        <a href="#label-session" class="nav-link">Label a session</a>
      </nav>
    </aside>

    <main class="content">

      <header class="page-header">
        <h1>Documentation</h1>
        <p>xIsland for macOS — setup and usage.</p>
      </header>

      <section id="installation">
        <h2>Installation</h2>

        <div class="option-grid">
          <div class="option-card">
            <div class="option-label">DMG</div>
            <p>Download from the <a href="/download" class="link">download page</a>, open the DMG, drag <strong>xIsland</strong> to Applications.</p>
          </div>
          <div class="option-card">
            <div class="option-label">Homebrew</div>
            <div class="codeblock"><code>brew install --cask xisland</code></div>
          </div>
        </div>

        <p>Launch xIsland. It appears in your menu bar and automatically connects to Claude Code, Codex, OpenCode, and Gemini CLI.</p>
      </section>

      <section id="reinstall-hooks">
        <h2>Reinstall hooks</h2>
        <p>If an agent update overwrites your config, or xIsland shows a hooks warning:</p>
        <ol>
          <li>Open <strong>Settings → Setup</strong>.</li>
          <li>Toggle the agent <strong>off</strong>, then <strong>on</strong>.</li>
        </ol>
        <p>No restart required.</p>
      </section>

      <section id="label-session">
        <h2>Label a session</h2>
        <p>Give a session a name that shows in the xIsland panel instead of the folder name.</p>
        <p>From inside a running Claude Code or Gemini CLI session:</p>
        <div class="codeblock"><code>!xisland rename "Auth refactor"</code></div>
        <p>The label updates immediately. The <code>!</code> runs the command without interrupting your agent.</p>
        <p class="aside">Requires the <code>xisland</code> CLI. Install it from <strong>Settings → Setup → Command line</strong>.</p>
      </section>

    </main>
  </div>
  <Footer />
</BaseLayout>

<script>
  const links = document.querySelectorAll<HTMLAnchorElement>('.nav-link');
  const sections = document.querySelectorAll<HTMLElement>('section[id]');

  function sync() {
    const atBottom = window.innerHeight + window.scrollY >= document.body.scrollHeight - 8;
    let active = sections[0]?.id ?? '';
    if (atBottom) {
      active = sections[sections.length - 1]?.id ?? active;
    } else {
      sections.forEach(s => {
        if (window.scrollY >= s.offsetTop - 100) active = s.id;
      });
    }
    links.forEach(l => l.classList.toggle('active', l.getAttribute('href') === `#${active}`));
  }

  window.addEventListener('scroll', sync, { passive: true });
  sync();
</script>

<style>
  .docs-root {
    display: grid;
    grid-template-columns: 220px 1fr;
    max-width: 900px;
    margin: 0 auto;
    padding: 100px 24px 120px;
    gap: 80px;
    align-items: start;
  }

  /* ── Sidebar ── */
  .sidenav {
    position: sticky;
    top: 88px;
    padding-top: 40px;
  }

  .nav-group-label {
    font-family: var(--mono);
    font-size: 9px;
    color: var(--text-3);
    text-transform: uppercase;
    letter-spacing: 0.1em;
    margin-bottom: 16px;
  }

  .nav-link {
    display: block;
    font-family: var(--mono);
    font-size: 12px;
    color: var(--text-3);
    padding: 8px 0 8px 14px;
    border-left: 2px solid transparent;
    transition: color 0.15s, border-color 0.15s;
  }

  .nav-link:hover { color: var(--text-2); }

  .nav-link.active {
    color: var(--green);
    border-left-color: var(--green);
  }

  /* ── Content ── */
  .content {
    padding-top: 40px;
  }

  .page-header {
    margin-bottom: 56px;
  }

  h1 {
    font-family: var(--mono);
    font-size: 24px;
    font-weight: 500;
    color: var(--text);
    margin-bottom: 8px;
  }

  .page-header p {
    color: var(--text-3);
    font-size: 13px;
    margin-bottom: 0;
  }

  section {
    padding-bottom: 64px;
    border-bottom: 1px solid var(--border);
    margin-bottom: 64px;
  }

  section:last-child {
    border-bottom: none;
    margin-bottom: 0;
  }

  h2 {
    font-family: var(--mono);
    font-size: 18px;
    font-weight: 500;
    color: var(--text);
    margin-bottom: 24px;
    letter-spacing: -0.01em;
  }

  p {
    font-family: var(--mono);
    font-size: 13px;
    color: var(--text-2);
    line-height: 2;
    margin-bottom: 18px;
    max-width: 560px;
  }

  p:last-child { margin-bottom: 0; }

  strong { color: var(--text); font-weight: 500; }

  ol {
    font-family: var(--mono);
    font-size: 13px;
    color: var(--text-2);
    line-height: 2;
    padding-left: 22px;
    margin-bottom: 18px;
    max-width: 560px;
  }

  ol li { margin-bottom: 4px; }

  /* Install options */
  .option-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 1px;
    background: var(--border);
    border: 1px solid var(--border);
    border-radius: var(--radius-sm);
    overflow: hidden;
    margin: 20px 0;
    max-width: 560px;
  }

  .option-card {
    background: var(--bg-elevated);
    padding: 24px 22px;
  }

  .option-label {
    font-size: 9px;
    color: var(--green);
    margin-bottom: 12px;
    letter-spacing: 0.06em;
  }

  .option-card p {
    margin-bottom: 0;
    font-size: 12px;
    color: var(--text-2);
  }

  /* Table */
  table {
    width: 100%;
    max-width: 560px;
    border-collapse: collapse;
    font-family: var(--mono);
    font-size: 11px;
    margin-top: 20px;
    border: 1px solid var(--border);
    border-radius: var(--radius-sm);
    overflow: hidden;
  }

  th {
    text-align: left;
    color: var(--text-3);
    font-weight: 400;
    font-size: 12px;
    padding: 12px 16px;
    background: var(--bg-elevated);
    border-bottom: 1px solid var(--border);
  }

  td {
    color: var(--text-2);
    font-size: 12px;
    padding: 12px 16px;
    border-bottom: 1px solid var(--border);
  }

  tr:last-child td { border-bottom: none; }
  td:first-child { color: var(--text); }

  /* Code */
  code {
    font-family: var(--mono);
    font-size: 12px;
    color: var(--green);
    background: var(--bg-card);
    padding: 2px 6px;
    border-radius: 4px;
  }

  .codeblock {
    background: var(--bg-card);
    border: 1px solid var(--border);
    border-radius: var(--radius-sm);
    padding: 14px 18px;
    margin: 16px 0;
    max-width: 560px;
  }

  .codeblock code {
    background: none;
    padding: 0;
    font-size: 13px;
  }

  .link {
    color: var(--green);
    text-decoration: underline;
    text-underline-offset: 3px;
    text-decoration-color: rgba(61, 220, 132, 0.35);
  }
  .link:hover { text-decoration-color: var(--green); }

  .aside {
    color: var(--text-3);
    font-size: 12px;
  }

  /* Mobile */
  @media (max-width: 768px) {
    .docs-root {
      grid-template-columns: 1fr;
      gap: 0;
      padding: 80px 16px 80px;
    }

    .sidenav {
      position: static;
      padding-top: 0;
      display: flex;
      gap: 0;
      border-bottom: 1px solid var(--border);
      margin-bottom: 40px;
    }

    .sidenav nav {
      display: flex;
      align-items: center;
      gap: 4px;
      flex-wrap: wrap;
    }

    .nav-group-label { display: none; }

    .nav-link {
      padding: 8px 12px;
      border-left: none;
      border-bottom: 2px solid transparent;
    }

    .nav-link.active {
      border-left: none;
      border-bottom-color: var(--green);
    }

    .option-grid { grid-template-columns: 1fr; }
  }
</style>
