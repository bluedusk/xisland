<section class="modes section">
  <div class="container">
    <h2>Two modes. As you wish.</h2>
    <p class="modes-sub">Choose your style. Switch anytime.</p>

    <div class="mode-cards">
      <!-- Notch mode -->
      <div class="mode-card">
        <div class="mode-preview notch-preview">
          <div class="preview-bar">
            <div class="preview-notch">
              <div class="preview-cam"></div>
            </div>
          </div>
          <div class="preview-island notch-island">
            <span class="pi-dot"></span>
            <span class="pi-text">claude code</span>
            <span class="pi-status">running</span>
          </div>
        </div>
        <div class="mode-info">
          <h3>
            <!-- Pixel notch icon -->
            <svg width="20" height="20" viewBox="0 0 16 16" shape-rendering="crispEdges">
              <rect x="0" y="0" width="5" height="2" fill="var(--green)"/>
              <rect x="11" y="0" width="5" height="2" fill="var(--green)"/>
              <rect x="5" y="0" width="6" height="4" fill="var(--text-3)"/>
              <rect x="0" y="2" width="16" height="2" fill="var(--green)" opacity="0.3"/>
            </svg>
            Notch
          </h3>
          <p>Lives in the macOS notch. Expands when your agent needs attention. Collapses when it doesn't.</p>
        </div>
      </div>

      <!-- Pill mode -->
      <div class="mode-card">
        <div class="mode-preview pill-preview">
          <div class="preview-bar">
            <div class="preview-notch">
              <div class="preview-cam"></div>
            </div>
          </div>
          <div class="preview-island pill-island">
            <span class="pi-dot green"></span>
            <span class="pi-text">codex</span>
            <span class="pi-status">3 tasks</span>
          </div>
        </div>
        <div class="mode-info">
          <h3>
            <!-- Pixel pill icon -->
            <svg width="20" height="20" viewBox="0 0 16 16" shape-rendering="crispEdges">
              <rect x="3" y="6" width="10" height="4" fill="var(--green)"/>
              <rect x="2" y="7" width="1" height="2" fill="var(--green)"/>
              <rect x="13" y="7" width="1" height="2" fill="var(--green)"/>
            </svg>
            Pill
          </h3>
          <p>Floating pill anywhere on your menu bar. Compact, always visible, out of the way.</p>
        </div>
      </div>
    </div>
  </div>
</section>

