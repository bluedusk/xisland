---
const agents = [
  {
    name: 'Claude Code',
    org: 'Anthropic',
    status: 'best',
    icon: `<svg width="18" height="18" viewBox="0 0 16 16" shape-rendering="crispEdges">
      <rect x="4" y="2" width="8" height="2" fill="var(--green)"/>
      <rect x="2" y="4" width="2" height="8" fill="var(--green)"/>
      <rect x="4" y="12" width="8" height="2" fill="var(--green)"/>
      <rect x="12" y="4" width="2" height="2" fill="var(--green)"/>
      <rect x="12" y="10" width="2" height="2" fill="var(--green)"/>
    </svg>`,
  },
  {
    name: 'Codex',
    org: 'OpenAI',
    status: 'supported',
    icon: `<svg width="18" height="18" viewBox="0 0 16 16" shape-rendering="crispEdges">
      <rect x="4" y="2" width="8" height="2" fill="var(--green)"/>
      <rect x="2" y="4" width="2" height="8" fill="var(--green)"/>
      <rect x="12" y="4" width="2" height="8" fill="var(--green)"/>
      <rect x="4" y="12" width="8" height="2" fill="var(--green)"/>
    </svg>`,
  },
  {
    name: 'OpenCode',
    org: 'Community',
    status: 'coming',
    icon: `<svg width="18" height="18" viewBox="0 0 16 16" shape-rendering="crispEdges">
      <rect x="4" y="3" width="2" height="2" fill="var(--green)"/>
      <rect x="2" y="5" width="2" height="2" fill="var(--green)"/>
      <rect x="0" y="7" width="2" height="2" fill="var(--green)"/>
      <rect x="2" y="9" width="2" height="2" fill="var(--green)"/>
      <rect x="4" y="11" width="2" height="2" fill="var(--green)"/>
      <rect x="10" y="3" width="2" height="2" fill="var(--green)"/>
      <rect x="12" y="5" width="2" height="2" fill="var(--green)"/>
      <rect x="14" y="7" width="2" height="2" fill="var(--green)"/>
      <rect x="12" y="9" width="2" height="2" fill="var(--green)"/>
      <rect x="10" y="11" width="2" height="2" fill="var(--green)"/>
    </svg>`,
  },
  {
    name: 'Gemini CLI',
    org: 'Google',
    status: 'coming',
    icon: `<svg width="18" height="18" viewBox="0 0 16 16" shape-rendering="crispEdges">
      <rect x="4" y="2" width="10" height="2" fill="var(--green)"/>
      <rect x="2" y="4" width="2" height="8" fill="var(--green)"/>
      <rect x="4" y="12" width="10" height="2" fill="var(--green)"/>
      <rect x="12" y="8" width="2" height="4" fill="var(--green)"/>
      <rect x="8" y="8" width="4" height="2" fill="var(--green)"/>
    </svg>`,
  },
];

const terminals = [
  { name: 'Ghostty', status: 'best' },
  { name: 'iTerm2', status: 'best' },
  { name: 'Terminal.app', status: 'supported' },
  { name: 'Warp', status: 'limited' },
  { name: 'WezTerm', status: 'supported' },
  { name: 'Kaku', status: 'coming' },
  { name: 'Cmux', status: 'supported' },
];
---

<section class="support section">
  <div class="container">
    <h2>Supported AI coding agents.</h2>
    <p class="support-sub">Works with Claude Code, Codex, Gemini CLI, and OpenCode.</p>

    <div class="grid">
      <div class="col">
        <h3>Agents</h3>
        <div class="items">
          {agents.map((a) => (
            <div class:list={['item', { coming: a.status === 'coming' }]}>
              <div class="item-icon" set:html={a.icon} />
              <div class="item-info">
                <span class="item-name">{a.name}</span>
                <span class="item-org">{a.org}</span>
              </div>
              {a.status === 'best' ? (
                <span class="badge best">Best experience</span>
              ) : a.status === 'supported' ? (
                <span class="badge supported">Supported</span>
              ) : (
                <span class="badge wip">Coming soon</span>
              )}
            </div>
          ))}
        </div>
      </div>

      <div class="col">
        <h3>Terminals</h3>
        <div class="items">
          {terminals.map((t) => (
            <div class:list={['item', 'item-terminal', { coming: t.status === 'coming' }]}>
              <span class="item-name">{t.name}</span>
              {t.status === 'best' ? (
                <span class="badge best">Best experience</span>
              ) : t.status === 'supported' ? (
                <span class="badge supported">Supported</span>
              ) : t.status === 'limited' ? (
                <span class="badge limited">Limited</span>
              ) : (
                <span class="badge wip">Coming soon</span>
              )}
            </div>
          ))}
        </div>
      </div>
    </div>
  </div>
</section>

<style>
  .support {
    text-align: center;
    border-top: 1px solid var(--border);
  }

  h2 {
    font-size: clamp(14px, 2.5vw, 20px);
    color: var(--text);
    margin-bottom: 12px;
  }

  .support-sub {
    font-family: var(--mono);
    font-size: 13px;
    color: var(--text-3);
    margin-bottom: 48px;
  }

  .grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 32px;
    max-width: 800px;
    margin: 0 auto;
    text-align: left;
  }

  h3 {
    font-size: 9px;
    color: var(--text-3);
    letter-spacing: 0.08em;
    margin-bottom: 16px;
    text-transform: uppercase;
  }

  .items {
    display: flex;
    flex-direction: column;
    border: 1px solid var(--border-2);
    border-radius: var(--radius);
    overflow: hidden;
  }

  .item {
    display: flex;
    align-items: center;
    gap: 14px;
    padding: 16px 20px;
    background: var(--bg);
    border-bottom: 1px solid var(--border-2);
    transition: background 0.2s;
  }

  .item:last-child {
    border-bottom: none;
  }

  .item:hover {
    background: var(--bg-elevated);
  }

  .item.coming {
    opacity: 0.4;
  }

  .item.coming:hover {
    opacity: 0.6;
  }

  .item-icon {
    flex-shrink: 0;
  }

  .item-info {
    display: flex;
    flex-direction: column;
    gap: 2px;
    flex: 1;
    min-width: 0;
  }

  .item-terminal {
    padding: 14px 20px;
  }

  .item-terminal .item-name {
    flex: 1;
  }

  .item-name {
    font-size: 9px;
    color: var(--text);
  }

  .item-org {
    font-family: var(--mono);
    font-size: 11px;
    color: var(--text-3);
  }

  .badge {
    font-family: var(--mono);
    font-size: 10px;
    padding: 3px 8px;
    border-radius: 4px;
    flex-shrink: 0;
    white-space: nowrap;
  }

  .badge.best {
    color: var(--green);
    background: rgba(61, 220, 132, 0.12);
    border: 1px solid rgba(61, 220, 132, 0.2);
  }

  .badge.supported {
    color: var(--text-2);
    background: rgba(255, 255, 255, 0.05);
  }

  .badge.limited {
    color: var(--orange);
    background: rgba(255, 138, 80, 0.1);
  }

  .badge.wip {
    color: var(--text-3);
    background: rgba(255, 255, 255, 0.03);
  }

  @media (max-width: 640px) {
    .grid {
      grid-template-columns: 1fr;
      gap: 24px;
    }
  }
</style>
