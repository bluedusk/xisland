<script>
  // Mascot pixel art
  const frame = [
    ".D....D.",
    ".MMMMMM.",
    ".MYEMYE.",
    ".MLKKML.",
    "DMHHHHDM",
    ".MHHHH..",
    "..K..K..",
    "........"
  ];
  const P = {
    '.':null, 'D':[107,77,170], 'M':[155,126,216], 'L':[184,150,240],
    'H':[212,192,240], 'E':[26,16,32], 'Y':[255,224,102], 'K':[255,179,71],
  };

  function drawMascot(id, opts) {
    const c = document.getElementById(id);
    if (!c) return;
    const ctx = c.getContext('2d');
    ctx.clearRect(0, 0, 8, 8);
    for (let y = 0; y < 8; y++) {
      for (let x = 0; x < 8; x++) {
        const col = P[frame[y][x]];
        if (!col) continue;
        let [r, g, b] = col;
        if (opts?.dim) {
          const a = r * 0.3 + g * 0.59 + b * 0.11;
          const m = 0.3;
          r = r * m + a * (1 - m);
          g = g * m + a * (1 - m);
          b = b * m + a * (1 - m);
        }
        if (opts?.tint) {
          const [tr, tg, tb] = opts.tint;
          const m = 0.35;
          r = r * (1 - m) + tr * m;
          g = g * (1 - m) + tg * m;
          b = b * (1 - m) + tb * m;
        }
        ctx.fillStyle = `rgb(${r|0},${g|0},${b|0})`;
        ctx.fillRect(x, y, 1, 1);
      }
    }
  }

  const BLUE = [87, 155, 255];
  const GREEN = [42, 232, 107];
  const ORANGE = [255, 155, 40];

  // Draw all mascots
  function drawAllMascots() {
    // Compact
    drawMascot('mascot-compact', { tint: BLUE });
    // Session list
    drawMascot('sess-m1', { tint: BLUE });
    drawMascot('sess-m2', { tint: BLUE });
    drawMascot('sess-m3', { tint: GREEN });
    // Approval
    drawMascot('appr-m', { tint: ORANGE });
    // Approved
    drawMascot('mascot-approved', { tint: GREEN });
    // Question
    drawMascot('ask-m', { tint: ORANGE });
    // Answered
    drawMascot('mascot-answered', { tint: BLUE });
    // Done
    drawMascot('done-m', { tint: GREEN });
  }

  drawAllMascots();

  // Queue-based animation system
  const queue = [];
  let timer = null;
  const island = document.getElementById('island');
  const labelEl = document.getElementById('demo-label');

  const sizes = {
    compact:  { w: 200, h: 32 },
    sessions: { w: 420, h: 280 },
    approval: { w: 420, h: 320 },
    approved: { w: 240, h: 36 },
    question: { w: 420, h: 320 },
    answered: { w: 240, h: 36 },
    done:     { w: 420, h: 220 },
  };

  function step(fn, delay) {
    queue.push({ fn, delay });
  }

  function showLayer(name) {
    document.querySelectorAll('#island .layer').forEach(l => l.classList.remove('active'));
    const el = document.querySelector(`[data-layer="${name}"]`);
    if (el) el.classList.add('active');
    const s = sizes[name];
    island.style.width = s.w + 'px';
    island.style.height = s.h + 'px';
    // Compact/confirmed states get pill radius
    if (name === 'compact' || name === 'approved' || name === 'answered') {
      island.style.borderRadius = '20px';
    } else {
      island.style.borderRadius = '0 0 28px 28px';
      island.style.borderTopColor = 'transparent';
    }
  }

  function setLabel(text) {
    if (labelEl) labelEl.textContent = text;
  }

  function highlightEl(id) {
    const el = document.getElementById(id);
    if (el) {
      el.style.transform = 'scale(1.05)';
      el.style.filter = 'brightness(1.3)';
      el.style.transition = 'transform 0.2s, filter 0.2s';
      setTimeout(() => {
        el.style.transform = '';
        el.style.filter = '';
      }, 400);
    }
  }

  // Build cinematic sequence
  function buildSequence() {
    // 1. Compact idle
    step(() => { showLayer('compact'); setLabel('idle'); }, 2000);
    // 2. Session list
    step(() => { showLayer('sessions'); setLabel('sessions'); }, 3000);
    // 3. Approval
    step(() => { showLayer('approval'); setLabel('approval'); }, 3000);
    // 4. Highlight approve button
    step(() => { highlightEl('btn-approve'); }, 800);
    // 5. Approved confirmation
    step(() => { showLayer('approved'); setLabel('allowed'); }, 1200);
    // 6. Compact
    step(() => { showLayer('compact'); setLabel('idle'); }, 1500);
    // 7. Question
    step(() => { showLayer('question'); setLabel('question'); }, 3000);
    // 8. Highlight option 1
    step(() => { highlightEl('q-opt-0'); }, 800);
    // 9. Answered confirmation
    step(() => { showLayer('answered'); setLabel('answered'); }, 1200);
    // 10. Compact
    step(() => { showLayer('compact'); setLabel('idle'); }, 1500);
    // 11. Done / jump
    step(() => { showLayer('done'); setLabel('done'); }, 2500);
    // 12. Compact, loop
    step(() => { showLayer('compact'); setLabel('idle'); }, 2000);
  }

  function run() {
    if (queue.length === 0) buildSequence();
    const next = queue.shift();
    if (next) {
      next.fn();
      timer = setTimeout(run, next.delay);
    }
  }

  setTimeout(run, 1000);
</script>

