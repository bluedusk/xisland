<script>
  // Queue-based cinematic animation system
  const queue = [];
  let timer = null;
  const island = document.getElementById('island');
  const labelEl = document.getElementById('demo-label');

  const sizes = {
    compact:  { w: 200, h: 32,  r: 20 },
    overview: { w: 380, h: 155, r: 14 },
    approval: { w: 360, h: 210, r: 14 },
    approved: { w: 240, h: 36,  r: 18 },
    ask:      { w: 330, h: 155, r: 14 },
    answered: { w: 240, h: 36,  r: 18 },
    jump:     { w: 380, h: 120, r: 14 },
  };

  const glows = {
    compact:  'rgba(34,197,94,0.08)',
    overview: 'rgba(59,130,246,0.08)',
    approval: 'rgba(249,115,22,0.12)',
    approved: 'rgba(34,197,94,0.15)',
    ask:      'rgba(6,182,212,0.12)',
    answered: 'rgba(6,182,212,0.15)',
    jump:     'rgba(34,197,94,0.12)',
  };

  function step(fn, delay) {
    queue.push({ fn, delay });
  }

  function showLayer(name) {
    document.querySelectorAll('.layer').forEach(l => l.classList.remove('active'));
    const el = document.querySelector(`[data-layer="${name}"]`);
    if (el) el.classList.add('active');
    const s = sizes[name];
    island.style.width = s.w + 'px';
    island.style.height = s.h + 'px';
    island.style.borderRadius = s.r + 'px';
    island.style.boxShadow = `0 4px 24px rgba(0,0,0,0.5), 0 0 20px ${glows[name]}, 0 0 0 0.5px rgba(255,255,255,0.06)`;
  }

  function setLabel(text) {
    if (labelEl) labelEl.textContent = text;
  }

  function highlightBtn(id) {
    const btn = document.getElementById(id);
    if (btn) {
      btn.style.transform = 'scale(1.05)';
      btn.style.filter = 'brightness(1.3)';
      setTimeout(() => {
        btn.style.transform = '';
        btn.style.filter = '';
      }, 400);
    }
  }

  // Build the cinematic sequence
  function buildSequence() {
    // 1. Compact idle
    step(() => { showLayer('compact'); setLabel('idle'); }, 2000);

    // 2. Expand to overview
    step(() => { showLayer('overview'); setLabel('sessions'); }, 2500);

    // 3. Approval comes in
    step(() => { showLayer('approval'); setLabel('approval'); }, 3000);

    // 4. User clicks Allow
    step(() => { highlightBtn('btn-allow'); }, 800);

    // 5. Collapse to approved confirmation
    step(() => { showLayer('approved'); setLabel('allowed'); }, 1200);

    // 6. Back to compact
    step(() => { showLayer('compact'); setLabel('idle'); }, 1800);

    // 7. Question comes in
    step(() => { showLayer('ask'); setLabel('question'); }, 2800);

    // 8. User picks option 1
    step(() => { highlightBtn('ask-opt-0'); }, 800);

    // 9. Collapse to answered confirmation
    step(() => { showLayer('answered'); setLabel('answered'); }, 1200);

    // 10. Back to compact briefly
    step(() => { showLayer('compact'); setLabel('idle'); }, 1500);

    // 11. Task done — jump view
    step(() => { showLayer('jump'); setLabel('done — jump'); }, 2500);

    // 12. Back to compact, loop
    step(() => { showLayer('compact'); setLabel('idle'); }, 2000);
  }

  function run() {
    if (queue.length === 0) buildSequence();
    const next = queue.shift();
    if (next) {
      next.fn();
      timer = setTimeout(run, next.delay);
    }
  }

  // Start after a brief pause
  setTimeout(run, 1000);
</script>

<style>
