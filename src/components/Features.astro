---

<section class="features section" id="features">
  <div class="container">
    <div class="features-header">
      <h2>Monitor every agent at a glance.</h2>
      <p class="features-sub">See what matters. Act when needed. Skip the noise.</p>
    </div>

    <div class="grid">
      {features.map((f) => (
        <div class="card">
          <div class="card-icon" set:html={f.icon} />
          <h3>{f.title}</h3>
          <p>{f.desc}</p>
        </div>
      ))}
    </div>
  </div>
</section>

<style>
  .features {
    background: var(--bg-2);
    border-top: 1px solid var(--border);
  }

  .features-header {
    text-align: center;
    margin-bottom: 48px;
  }

  .features-header h2 {
    font-size: clamp(14px, 2.5vw, 20px);
    color: var(--text);
    margin-bottom: 12px;
    line-height: 1.4;
  }

  .features-sub {
    font-family: var(--mono);
    font-size: 13px;
    color: var(--text-3);
  }

  .grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 1px;
    background: var(--border-2);
    border: 1px solid var(--border-2);
    border-radius: var(--radius);
    overflow: hidden;
  }

  .card {
    padding: 36px 28px;
    background: var(--bg);
    transition: background 0.25s;
  }

  .card:hover {
    background: var(--bg-elevated);
  }

  .card-icon {
    margin-bottom: 20px;
    opacity: 0.8;
    transition: opacity 0.2s, filter 0.2s;
  }

  .card:hover .card-icon {
    opacity: 1;
    filter: drop-shadow(0 0 4px var(--green-glow));
  }

  h3 {
    font-size: 11px;
    color: var(--text);
    margin-bottom: 12px;
  }

  p {
    font-family: var(--mono);
    font-size: 12px;
    line-height: 1.7;
    color: var(--text-2);
  }

  @media (max-width: 768px) {
    .grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  @media (max-width: 480px) {
    .grid {
      grid-template-columns: 1fr;
    }

    .card {
      padding: 24px 20px;
    }
  }
</style>
